class MyLinkedList {
public:
    struct node
    {
        int val;
        struct node *next;
        node(int x) {
        val = x;
        next = NULL;
    }
    };
    struct node*head=NULL;
    MyLinkedList() {
        
    }
    
    int get(int index) {
        if(index<0)
        index=0;
        if(!head)
        {
            return -1;
        }
        struct node *p=head;
        int i=0;
        while(i<index && p!=NULL)
        {
            p=p->next;
            i++;
        }
    if(p==NULL)
    return -1;
    else
    return p->val;      
    }
    
    void addAtHead(int val) {
        node *n=new node(val);
            n->next=head;
            head=n;        
    }
    
    void addAtTail(int val) {
        if(head==NULL)
        addAtHead(val);
        else
        {
            node *n=new node(val);
            struct node *p=head;
            while(p->next!=NULL)
            p=p->next;
            p->next=n;
        }
        
    }
    // better approach can be to first traverse and count number of nodes and then if possible to add then simply add by trtaversing else not, doubly's case use this onlyor traversal as O(n) is only there
    void addAtIndex(int index, int val) {
        if(index<0)
        index=0;
        if(!head || index==0)
        {
            if(index==0)
        addAtHead(val);
        return;
        }
        else
        {
            int i=0;
            struct node *p=head;
            while(i<index-1 && p->next!=NULL)
            {
                p=p->next;
                i++;
            }
            if(p->next==NULL && i==index-1)
            addAtTail(val);
            else if(p->next==NULL)
            return;
            else
            {
                node *n=new node(val);
                n->next=p->next;
                p->next=n;
            }

        }
        
    }
    
   void deleteAtIndex(int index) {
    if(index<0)
    index=0;

    if(!head)
    return;

    if(index==0)
    {
        struct node*temp=head;
        head=head->next;
        delete temp;
        return;
    }
    int i=0;
    struct node *p=head;
    while(i<index-1 && p!=NULL)
    {
        p=p->next;
        i++;
    }

    if(p==NULL || p->next==NULL)
    return;

    struct node*temp=p->next;
    p->next=temp->next;
    delete temp;

}
};

