#include<cmath>
class MedianFinder {
public:
    priority_queue<int> maxh;
    priority_queue<int,vector<int>,greater<int>> minh;


    MedianFinder() {
        
    }
    
    void addNum(int num) {
        if(maxh.empty()||num<=maxh.top())
        maxh.push(num);
        else
        minh.push(num);
        if(minh.size()+1<maxh.size()|| maxh.size()+1<minh.size())
        {
            if(minh.size()>maxh.size())
            {
                maxh.push(minh.top());
                minh.pop();
            }
            else
            {
                minh.push(maxh.top());
                maxh.pop();
            }
        }

        
    }
    
    double findMedian() {
        if(minh.size()==maxh.size())
        return (minh.top()+maxh.top())/2.0;
        else if(minh.size()>maxh.size())
        return minh.top();
        else
        return maxh.top();     

    }
};

