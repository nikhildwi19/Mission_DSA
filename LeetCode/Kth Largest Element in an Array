class Solution {
public:
    int findKthLargest(vector<int>& nums, int k) {
        priority_queue<int,vector<int>,greater<int>> min;
        int n=nums.size();
        for(int i=0;i<k;i++)
        {
            min.push(nums[i]);
        }
        for(int i=k;i<n;i++)
        {
            if(nums[i]>min.top())
            {
                min.pop();
                min.push(nums[i]);
            }

        }
        return min.top();

        
    }
};
